$var reg       1 U    sync_active $end
$upscope $end

$upscope $end


$scope module DUT $end
$var parameter 32 V    CLK_FREQ_HZ $end
$var parameter 32 W    BAUD_RATE $end
$var wire      1 "    clk  $end
$var wire      1 X    rst_n  $end
$var wire      8 Y    prescaler [7:0] $end
$var wire      3 Z    prop_seg [2:0] $end
$var wire      3 [    phase_seg1 [2:0] $end
$var wire      3 \    phase_seg2 [2:0] $end
