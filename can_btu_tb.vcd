$var reg       1 >    sample_tick $end
$var reg       1 ?    tx_tick $end
$var reg       1 @    sample_point $end
$var reg       8 A    bit_time_cnt [7:0] $end
$var reg       1 B    sync_locked $end
$var reg       1 C    edge_detected $end
$var reg       1 D    sync_active $end
$upscope $end


$scope clocking mon_cb $end
$var reg       1 E    rst_n $end
$var reg       8 F    prescaler [7:0] $end
$var reg       3 G    prop_seg [2:0] $end
$var reg       3 H    phase_seg1 [2:0] $end
$var reg       3 I    phase_seg2 [2:0] $end
$var reg       2 J    sjw [1:0] $end
