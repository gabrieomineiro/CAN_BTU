$scope module tb_can_btu $end
$var reg       1 !    clk $end

$scope module btu_if $end
$var wire      1 "    clk  $end
$var reg       1 #    rst_n $end
$var reg       8 $    prescaler [7:0] $end
$var reg       3 %    prop_seg [2:0] $end
$var reg       3 &    phase_seg1 [2:0] $end
$var reg       3 '    phase_seg2 [2:0] $end
