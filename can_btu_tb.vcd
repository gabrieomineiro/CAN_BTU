$var wire      1 ^    can_rx  $end
$var wire      1 _    sync_en  $end
$var wire      1 `    hard_sync  $end
$var reg       1 a    bit_tick $end
$var reg       1 b    sample_tick $end
$var reg       1 c    tx_tick $end
$var reg       1 d    sample_point $end
$var reg       8 e    bit_time_cnt [7:0] $end
